{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "lib": ["ES2022", "DOM"],
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "moduleResolution": "Node",
    "declaration": true,
    "sourceMap": true,
    "baseUrl": ".",
    "paths": {
      "@novel-factory/shared": ["packages/shared/src"],
      "@novel-factory/llm": ["packages/llm/src"],
      "@novel-factory/memory": ["packages/memory/src"]
    }
  }
}
